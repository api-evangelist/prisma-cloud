        {
          "id": "bbe41bc3-8b67-462a-8deb-8cb8f99534fc",
          "name": "Extend (refresh) the JWT",
          "request": {
            "name": "Extend (refresh) the JWT",
            "description": {
              "content": "Refreshes the current JWT before it expires. Must be called with a still-valid\ntoken; if the token has already expired the caller must re-authenticate via\nPOST /login.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "auth_token",
                "extend"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "Region-specific API hostname for the customer's stack (api, api2, api.eu, api.gov, ...).",
                  "type": "any",
                  "value": "{{stack}}",
                  "key": "stack"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "key",
                  "value": "x-redlock-auth"
                },
                {
                  "key": "value",
                  "value": "{{apiKey}}"
                },
                {
                  "key": "in",
                  "value": "header"
                }
              ]
            }
          },
          "response": [
            {
              "id": "fbb04635-deb3-4171-9aec-9e4b26c78918",
