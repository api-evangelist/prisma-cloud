      "item": [
        {
          "id": "8c57ca9a-d4af-437e-8048-891074bcb0ed",
          "name": "Log in and obtain a JWT",
          "request": {
            "name": "Log in and obtain a JWT",
            "description": {
              "content": "Exchanges an Access Key ID and Secret Key for a short-lived (10 minute)\nJSON Web Token used to authenticate subsequent Prisma Cloud API calls.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "login"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "Region-specific API hostname for the customer's stack (api, api2, api.eu, api.gov, ...).",
                  "type": "any",
                  "value": "{{stack}}",
                  "key": "stack"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"<string>\",\n  \"password\": \"<string>\",\n  \"customerName\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "345922ef-3a9e-4620-bdab-562d1f3c9697",
              "name": "Login successful; returns a JWT.",
              "originalRequest": {
                "url": {
                  "path": [
                    "login"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
                  "variable": [
                    {
                      "description": "Region-specific API hostname for the customer's stack (api, api2, api.eu, api.gov, ...).",
                      "type": "any",
                      "value": "{{stack}}",
                      "key": "stack"
                    }
                  ]
